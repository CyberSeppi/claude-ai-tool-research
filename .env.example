# Copy to .env (gitignored). The app loads this at startup.
# Values shown below are sensible defaults — overwrite the placeholders.

# ─── LLM (chat backend) ──────────────────────────────────────────────
# Two providers are supported; pick one via LLM_PROVIDER:
#
#   api  — direct HTTP to an OpenAI-compatible /chat/completions endpoint
#          (Anthropic via official SDK, BMW GenAI gateway, Azure OpenAI,
#          self-hosted vLLM, …). DEFAULT — works inside the container.
#
#   cli  — wraps the local `claude` CLI via @anthropic-ai/claude-agent-sdk.
#          Requires the CLI to be installed (Pro/Max subscription path,
#          no API key needed). Useful for free local dev; NOT available
#          inside the Docker container.
LLM_PROVIDER=api

# Required when LLM_PROVIDER=api. The same key + secret pair used by the
# BMW GenAI machine-to-machine flow; the gateway accepts both x-apikey and
# Authorization: Bearer headers (see app/server/llm/provider-api.mjs).
LLM_API_KEY=
LLM_AUTH_CLIENT_ID=
LLM_AUTH_CLIENT_SECRET=

# OpenAI-compatible base URL — the app posts to {BASE_URL}/chat/completions.
# Default targets BMW's GenAI gateway. For Anthropic direct, use
# https://api.anthropic.com/v1 and set LLM_AUTH_* to your API key.
LLM_API_BASE_URL=https://api.gcp.cloud.bmw/llmapi/v1
LLM_AUTH_TOKEN_URL=https://auth.bmwgroup.net/auth/oauth2/realms/root/realms/machine2machine/access_token
LLM_AUTH_SCOPE=machine2machine

LLM_MODEL=gpt-4o
LLM_MAX_COMPLETION_TOKENS=4096


# ─── Embeddings (RAG retrieval) ──────────────────────────────────────
# When EMBEDDINGS_ENABLED=true, the app embeds every record on /api/refresh
# and uses semantic top-K retrieval for global-scope chat (instead of
# stuffing all 143 records into the context).
#
# Uses the same OpenAI-compatible shape as the LLM block. You can reuse
# the LLM_* secrets — BMW's gateway accepts one M2M client for both.
EMBEDDINGS_ENABLED=true
EMBEDDINGS_API_KEY=
EMBEDDINGS_AUTH_CLIENT_ID=
EMBEDDINGS_AUTH_CLIENT_SECRET=
EMBEDDINGS_API_BASE_URL=https://api.gcp.cloud.bmw/llmapi/v1
EMBEDDINGS_AUTH_TOKEN_URL=https://auth.bmwgroup.net/auth/oauth2/realms/root/realms/machine2machine/access_token
EMBEDDINGS_AUTH_SCOPE=machine2machine

EMBEDDINGS_MODEL=text-embedding-3-large
# Must match the model's native output dimension. Asserted at first call —
# mismatch → the app refuses to start.
EMBEDDINGS_DIMENSIONS=3072

# Top-K records pulled per chat call. Lower = cheaper context, less recall.
EMBEDDINGS_RETRIEVAL_TOP_K=8
# Minimum cosine similarity for a hit to count. 0.0 disables the floor.
EMBEDDINGS_RETRIEVAL_MIN_SCORE=0.0


# ─── README fetching (RAG chunks) ────────────────────────────────────
# Read-only PAT for fetching repo READMEs at backfill time.
# https://github.com/settings/tokens — only "public_repo" scope is needed.
# If unset/empty, only the 'fields' chunk per record is embedded.
GITHUB_TOKEN=

# Bump to invalidate all stored embeddings (e.g. after changing the
# embed-source template in app/server/embeddings/source.mjs).
EMBEDDINGS_PROMPT_VERSION=1

# Run the boot-time backfill that embeds every record's fields + README.
# When false, the index stays cold and scope=global chat falls back to
# full-context (today's behaviour).
EMBEDDINGS_BACKFILL_ON_STARTUP=true

# Embed batch size (max inputs per /embeddings call).
EMBEDDINGS_BATCH_SIZE=32

# Heading-aware split: sections longer than this character count get
# char-split with 200-char overlap as fallback.
EMBEDDINGS_CHUNK_MAX_CHARS=1500
