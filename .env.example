# Copy this file to `.env` (gitignored) and fill in the secrets.
# The app loads `.env` at startup via `run.sh --env-file`.

# ═══════════════════════════════════════════════════════════════════════
# LLM (chat backend)
# ═══════════════════════════════════════════════════════════════════════
#
# Two providers are supported, picked via LLM_PROVIDER:
#
#   api  — direct HTTP POST to an OpenAI-compatible /chat/completions
#          endpoint. Default. Works inside the Docker container. Use this
#          with Anthropic's official API, Azure OpenAI, vLLM, an internal
#          corporate gateway, or anything else that speaks the OpenAI
#          chat-completions wire format.
#
#   cli  — wraps the local `claude` CLI via @anthropic-ai/claude-agent-sdk.
#          See the "Provider: cli" section in README.md for the licensing
#          caveat — short version: do NOT ship this provider to a shared
#          / multi-user / hosted app.
#
LLM_PROVIDER=api


# ─── LLM_PROVIDER=api settings ───────────────────────────────────────
#
# Anthropic direct (most users, default-ish defaults):
#   LLM_API_BASE_URL=https://api.anthropic.com/v1
#   LLM_API_KEY=sk-ant-...          # your Anthropic API key
#   LLM_MODEL=claude-sonnet-4-6
#
# Some corporate / internal gateways require an additional machine-to-
# machine OAuth client_credentials flow on top of the API key. If yours
# does, set LLM_AUTH_* and the app will exchange your client credentials
# for a bearer token before each call. Leave LLM_AUTH_* empty for
# Anthropic direct.
#
LLM_API_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_COMPLETION_TOKENS=4096

# Optional — only required when your gateway needs OAuth M2M on top of
# the API key. Anthropic direct does NOT need these.
LLM_AUTH_CLIENT_ID=
LLM_AUTH_CLIENT_SECRET=
LLM_AUTH_TOKEN_URL=
LLM_AUTH_SCOPE=


# ─── LLM_PROVIDER=cli settings ───────────────────────────────────────
#
# Pick ONE of the three auth modes below. The app refuses to start if
# LLM_PROVIDER=cli and none of them apply.
#
# Mode A: Anthropic API key (simplest)
#   ANTHROPIC_API_KEY=sk-ant-...
#   ANTHROPIC_BASE_URL=    # leave empty → api.anthropic.com
#
# Mode B: Local Anthropic-compat router (CCR, litellm, claude-bridge, …)
#   ANTHROPIC_BASE_URL=http://host.docker.internal:3456
#   ANTHROPIC_AUTH_TOKEN=<router-issued-token>
#   # host.docker.internal:<port> is auto-wired by run.sh so a value like
#   # http://host.docker.internal:3456 reaches a service on the host.
#
# Mode C: Mounted Pro/Max OAuth session (no env vars at all)
#   Run `claude /login` on the host before starting the container so
#   ~/.claude/.credentials.json contains a claudeAiOauth.accessToken.
#   run.sh bind-mounts that file into the container automatically.
#
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=


# ═══════════════════════════════════════════════════════════════════════
# Embeddings (RAG retrieval) — optional
# ═══════════════════════════════════════════════════════════════════════
#
# When EMBEDDINGS_ENABLED=true, the app embeds every record on boot and
# uses semantic top-K retrieval for global-scope chat (instead of
# stuffing all records into the prompt).
#
# Uses the OpenAI-compatible /embeddings endpoint shape. Voyage AI,
# OpenAI direct, Azure OpenAI, and most internal corporate gateways
# work. Set EMBEDDINGS_ENABLED=false to skip RAG entirely; the chat
# falls back to today's full-context behaviour.
#
EMBEDDINGS_ENABLED=true
EMBEDDINGS_API_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-large
# Must match the model's native output dimension. Asserted on the first
# response — mismatch → the app refuses to start.
EMBEDDINGS_DIMENSIONS=3072

# Optional OAuth M2M (same shape as the LLM_AUTH_* block above). Leave
# empty for OpenAI / Voyage / Anthropic direct.
EMBEDDINGS_AUTH_CLIENT_ID=
EMBEDDINGS_AUTH_CLIENT_SECRET=
EMBEDDINGS_AUTH_TOKEN_URL=
EMBEDDINGS_AUTH_SCOPE=

# Top-K records pulled per chat call. Lower = cheaper context, less recall.
EMBEDDINGS_RETRIEVAL_TOP_K=8
# Minimum cosine similarity for a hit. 0.0 disables the floor.
EMBEDDINGS_RETRIEVAL_MIN_SCORE=0.0

# Bump to invalidate all stored embeddings (e.g. after changing the
# embed-source template in app/server/embeddings/source.mjs).
EMBEDDINGS_PROMPT_VERSION=1
EMBEDDINGS_BACKFILL_ON_STARTUP=true
EMBEDDINGS_BATCH_SIZE=32
# Heading-aware split: README sections longer than this get char-split.
EMBEDDINGS_CHUNK_MAX_CHARS=1500


# ═══════════════════════════════════════════════════════════════════════
# Container CA bundle (optional — only if your network does TLS intercept)
# ═══════════════════════════════════════════════════════════════════════
#
# If you're behind a corporate proxy / on-prem gateway that re-signs
# outbound TLS, set this to the URL of a PEM bundle that includes that
# root CA. `run.sh --build` will bake it into the image and Node.js will
# pick it up via NODE_EXTRA_CA_CERTS. Leave empty for normal networks.
#
EXTRA_CA_BUNDLE_URL=


# ═══════════════════════════════════════════════════════════════════════
# README fetching (RAG chunks)
# ═══════════════════════════════════════════════════════════════════════
#
# Read-only PAT for fetching repo READMEs at backfill time.
# https://github.com/settings/tokens — `public_repo` scope is enough.
# Without it, only the 'fields' chunk per record is embedded.
#
GITHUB_TOKEN=
